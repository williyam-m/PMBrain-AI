# ──────────────────────────────────────────────
# PMBrain AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*
DATABASE_URL=sqlite:///db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─── Gemini AI ────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=abc
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT=60

# ─── File Upload ──────────────────────────────
MAX_CODEBASE_SIZE_MB=100
CODEBASE_STORAGE_PATH=media/codebases

# ─── GitHub Integration (Optional) ───────────
# For OAuth flow (requires GitHub OAuth App):
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
# For token encryption (auto-generated from SECRET_KEY if blank):
GITHUB_ENCRYPTION_KEY=
# Repo limits:
MAX_GITHUB_REPO_SIZE_MB=200
GITHUB_CLONE_TIMEOUT=120
